{
  "expo": {
    "name": "aulaia-app",
    "slug": "aulaia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cr.ezekl.aulaia"
    },
    "android": {
      "package": "cr.ezekl.aulaia",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-auth0",
        {
          "domain": "aulaia-mep.us.auth0.com"
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "AulaIA necesita acceso a la cámara para escanear códigos QR de asistencia."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a56db",
          "sounds": []
        }
      ]
    ],
    "scheme": "aulaia",
    "extra": {
      "eas": {
        "projectId": "58d237e5-c82d-4ccf-9b05-27b66fcb6246"
      }
    },
    "owner": "ezekiell1988"
  }
}
